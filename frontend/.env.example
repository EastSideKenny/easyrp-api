# Laravel API base URL (no trailing slash)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# App domain for multi-tenant subdomain resolution
# In development: "localhost" (access tenants via acme.localhost:3000)
# In production:  "easyrp.com" (access tenants via acme.easyrp.com)
NUXT_PUBLIC_APP_DOMAIN=localhost

# Public marketing site URL for canonical links, Open Graph (no trailing slash).
# Production: set explicitly (e.g. https://easyrp.com). If unset, sitemap.xml still
# builds <loc> URLs from the request host so Google Search Console gets valid entries.
# NUXT_PUBLIC_SITE_URL=https://easyrp.com

# Stripe.js publishable key (subscription checkout in app UI)
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_key

# Google Analytics 4 — Measurement ID (optional)
# NUXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console — HTML tag verification content value only (optional)
# NUXT_PUBLIC_GSC_VERIFICATION=your_verification_token
